{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Just Text",
  "version": "1.0.0",
  "identifier": "com.justtext.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Just Text",
        "width": 1000,
        "height": 680,
        "minWidth": 640,
        "minHeight": 420,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
